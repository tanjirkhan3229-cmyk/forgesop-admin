# ForgeSOP Platform Admin Console — backend environment.
# Copy to backend/.env (or export in the deploy environment). NEVER commit real
# values: this service holds the Supabase SERVICE-ROLE key, which bypasses RLS.

APP_ENV=development

# ── Shared Supabase Postgres, as the SERVICE-ROLE Postgres role ──────────────
# RLS-bypassing cross-tenant reads of public.*; writes ONLY to
# public.workspaces.feature_* (via apply_plan, Phase 2). Async driver (asyncpg).
# search_path is pinned to platform,public by core/db.py.
DATABASE_URL=postgresql+asyncpg://service_role:CHANGE_ME@db.YOUR_REF.supabase.co:5432/postgres

# Supabase project + service-role key (used by the Supabase Admin API for
# impersonation in Phase 4; the service-role key must live ONLY here, never in
# any browser).
SUPABASE_URL=https://YOUR_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=CHANGE_ME

# ── Operator identity (DISTINCT issuer/audience from the tenant project) ─────
# A tenant Supabase JWT must never satisfy the platform gate, so the operator
# IdP uses its own issuer + audience + JWKS. verify_platform_token REQUIRES both.
PLATFORM_JWT_ISSUER=https://operators.forgesop.app/
PLATFORM_JWT_AUDIENCE=forgesop-admin-console
PLATFORM_JWKS_URL=https://operators.forgesop.app/.well-known/jwks.json

# CORS — the admin SPA origin.
ADMIN_ORIGIN=http://localhost:5173

# ── Celery / Redis (Phase 3 — footprint + signup rollups) ────────────────────
# The console runs its OWN Celery worker + beat against its OWN Redis. Pin a
# SEPARATE logical DB index (CELERY_DB_INDEX) so admin queues never collide with
# anything else on the Redis host. Run with:
#   celery -A app.tasks worker --beat --loglevel=info
REDIS_URL=redis://localhost:6379
CELERY_DB_INDEX=1
# Optional explicit overrides (default: ${REDIS_URL}/${CELERY_DB_INDEX}):
# CELERY_BROKER_URL=
# CELERY_RESULT_BACKEND=

# Footprints: trailing days the detail trend returns, and the default
# "inactive >= N days" directory threshold.
FOOTPRINT_TREND_DAYS=30
FOOTPRINT_INACTIVE_DAYS_DEFAULT=14
