# ForgeSOP Platform Admin SPA — frontend environment (Vite, VITE_ prefix).
# Copy to admin/.env.local. These are PUBLIC build-time values — the operator
# token is short-lived and the service-role key is NEVER exposed to the browser.

# Auth mode. Set true to use the console's built-in email+password login
# (matches backend PLATFORM_LOCAL_AUTH). Leave false/unset to use SSO/OIDC.
VITE_LOCAL_AUTH=false

# Operator OIDC client (distinct issuer/audience from the tenant Supabase project).
VITE_OIDC_ISSUER=https://operators.forgesop.app
VITE_OIDC_CLIENT_ID=forgesop-admin-spa
VITE_OIDC_AUDIENCE=forgesop-admin-console
VITE_OIDC_REDIRECT_URI=http://localhost:5173/

# Admin API base. Empty string uses the Vite dev proxy (/v1 -> :8000); in
# production set the admin API origin, e.g. https://admin-api.forgesop.app
VITE_ADMIN_API_BASE=
