# ForgeSOP Platform Admin Console — backend environment.
# Copy to backend/.env. NONE of these belong in any browser bundle; the
# service-role key and Stripe secrets live ONLY in this service's environment.

APP_ENV=development

# ── Shared Supabase Postgres (SERVICE-ROLE role; RLS-bypassing) ──────────────
# Async driver (asyncpg). search_path is pinned to platform,public by core/db.py.
#   postgresql+asyncpg://service_role:...@db.<ref>.supabase.co:5432/postgres
DATABASE_URL=sqlite+aiosqlite://
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Operator identity (DISTINCT issuer/audience from the tenant project) ─────
# A tenant Supabase JWT must never satisfy the platform gate.
PLATFORM_JWT_ISSUER=https://operators.forgesop.app
PLATFORM_JWT_AUDIENCE=forgesop-admin-console
PLATFORM_JWKS_URL=https://operators.forgesop.app/.well-known/jwks.json

# CORS — the admin SPA origin.
ADMIN_ORIGIN=http://localhost:5173

# ── Stripe billing (Phase 6 — optional) ─────────────────────────────────────
# Leave blank to keep billing OFF. With both set, the webhook flips plans and
# the invoices view works. The webhook secret is required to accept any event.
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_WEBHOOK_TOLERANCE_SECONDS=300

# ── Redis + Celery (Phase 7 — alert sweeps & operator digest) ────────────────
# The admin service's OWN Redis (not the tenant app's). The API process doesn't
# need the broker; the worker/beat do:
#   celery -A app.core.celery_app.celery worker --beat
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=
ALERT_SWEEP_INTERVAL_MINUTES=15
DIGEST_HOUR_UTC=13
